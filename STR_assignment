SELECT * FROM ORDERS;

--QUERIES.
-- Write a query to convert all customer names to uppercase.
SELECT UPPER(Customer_Name) from ORDERS;
----a query to convert all customer names to LOWERCASE
SELECT LOWER(Customer_Name) FROM ORDERS;
--Extract the first 5 characters from Product_Name.
SELECT SUBSTR(Product_Name,1,5) AS NAME_5 FROM ORDERS;
--Find the length of each Customer_Name.
SELECT LENGTH (Customer_Name) FROM ORDERS;
--Replace the word "Rice" with "Premium Rice" in Product_Name.
SELECT REPLACE (Product_Name,'Rice','Premium Rice') AS UPDATED_RICE FROM ORDERS;
--Remove leading and trailing spaces from Customer_Name.
SELECT TRIM(Customer_Name) AS SPACE FROM ORDERS;
--Concatenate First_Name and Last_Name as Full_Name.
select Customer_Name || ''|| Product_Name as full_name
from orders;
--Find customers whose names start with 'A'
SELECT *
FROM Orders
WHERE Customer_Name like 'A%';
--Convert the first letter of each word in Product_Name to uppercase.
SELECT Product_Name initcap FROM ORDERS;
--Reverse the Reverse the Product_Name.
SELECT REVERSE (Product_Name) AS Reversed_Name FROM ORDERS;
--Extract the domain name from Email_ID
SELECT SUBSTRING(customer_id,CHARINDEX('@', customer_id) + 1,LEN(customer_id)) AS domain_name
FROM Orders;

-- Convert the first letter of each word in Product_Name to uppercase.
SELECT INITCAP (Product_Name) AS DUAL FROM ORDERS;
--Extract the last 3 characters from Order_ID.
SELECT SUBSTR('Order_ID',1,4) FROM ORDERS;
--Count how many times letter 'a' appears in Customer_Name. Count how many times letter 'a' appears in Customer_Name.
SELECT LENGTH(Customer_Name)-LENGTH(REPLACE(LOWER(Customer_Name),'a','')) AS CountA
FROM Orders;
-- Extract the last 3 characters from Order_ID.
SELECT SUBSTR(Order_ID,2,4) AS LAST_3 FROM ORDERS;
--Mask the last 4 digits of a phone number.

--Split Full_Name into First_Name and Last_Name.
SELECT SUBSTR(Customer_Name,1,INSTR(Customer_Name,' ')-1) as F_Name,
