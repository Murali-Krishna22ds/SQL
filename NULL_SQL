DROP TABLE ORDERS;


CREATE TABLE orders (
    order_id      NUMBER PRIMARY KEY,
    customer_name VARCHAR2(100),
    product_name  VARCHAR2(100),
    quantity      NUMBER,
    unit_price    NUMBER(10,2),
    order_date    DATE
);



